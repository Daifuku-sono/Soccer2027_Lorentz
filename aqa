#include <Arduino.h>
#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_ST7789.h>
#include <avr/pgmspace.h>
#include <math.h>

// ----- 配線 -----
// GND  -> GND
// VCC  -> 3V3
// SCL  -> D8
// SDA  -> D10
// RES  -> D3
// DC   -> D4
// CS   -> D5
// BLK  -> 3V3

constexpr uint8_t TFT_CS  = 5;
constexpr uint8_t TFT_DC  = 4;
constexpr uint8_t TFT_RST = 3;
constexpr uint8_t BUTTON_PIN = 0;   // 元のままD0を使用。Serialと併用するなら注意

Adafruit_ST7789 tft(TFT_CS, TFT_DC, TFT_RST);

// 240x240px の1bit bitmap
constexpr int IMG_W = 240;
constexpr int IMG_H = 240;

// ===== ここに bitmap を貼る =====
const unsigned char epd_bitmap_image[] PROGMEM = {
  // 例:
  // 0x00, 0x00, ...
};

// 表示モード
// 0: 黒画面
// 1: bitmap 表示
// 2: bitmap + 線
uint8_t mode = 0;
uint8_t lastButtonState = HIGH;

// 線の角度（必要に応じて外部から更新してください）
float angle = 0.0f;

void drawScreen() {
  tft.fillScreen(ST77XX_BLACK);

  if (mode == 1 || mode == 2) {
    tft.drawBitmap(0, 0, epd_bitmap_image, IMG_W, IMG_H, ST77XX_MAGENTA);
  }

  if (mode == 2) {
    float rad = angle * DEG_TO_RAD;
    int16_t x = 120 + (int16_t)(100.0f * cosf(rad));
    int16_t y = 120 + (int16_t)(100.0f * sinf(rad));

    tft.drawLine(120, 120, x, y, ST77XX_WHITE);
  }
}

void setup() {
  Serial.begin(115200);
  delay(500);

  SPI.begin();

  tft.init(240, 240);
  tft.setRotation(2);   // 必要なら 1,2,3 を試す
  tft.fillScreen(ST77XX_BLACK);

  pinMode(BUTTON_PIN, INPUT_PULLUP); // ボタンはGNDに落とす配線にする
  drawScreen();
}

void loop() {
  uint8_t buttonState = digitalRead(BUTTON_PIN);

  // 押した瞬間だけ mode を進める
  if (lastButtonState == HIGH && buttonState == LOW) {
    mode++;
    if (mode >= 3) mode = 0;
    drawScreen();

    Serial.print("mode = ");
    Serial.println(mode);
  }

  lastButtonState = buttonState;
}